generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @db.Uuid @default(uuid())
  email     String   @unique
  role      UserRole     @default(BRAND)
  companyName String
  contactInfo Json?
  capabilities String[] @default([])
  isActive Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  BRAND
  MANUFACTURER
  ADMIN
}
